{
  "name": "lilygo-doc-mcp",
  "version": "1.0.0",
  "description": "MCP server for LILYGO product documentation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "docs:init": "git submodule update --init --depth 1 vendor/docs",
    "docs:update": "git submodule update --remote --merge vendor/docs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lilygo",
    "esp32",
    "documentation",
    "iot"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
